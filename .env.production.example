# ── Production environment template ───────────────────────────────
# Copy this to `.env.production` ON THE VPS (never commit the real one).
#   cp .env.production.example .env.production && nano .env.production

# MySQL connection (use a dedicated prod DB + strong password)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=events_prod
MYSQL_PASSWORD=change-me-to-a-strong-password
MYSQL_DATABASE=events_lk

# Node runtime
NODE_ENV=production
PORT=3001
